{
  "expo": {
    "name": "GusPad",
    "slug": "guspad-mobile",
    "version": "1.0.0",
    "sdkVersion": "54.0.0",
    "orientation": "portrait",
    "icon": "./assets/gplogo.png",
    "userInterfaceStyle": "light",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#0C2729"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "plugins": [
      "expo-secure-store",
      "expo-asset",
      "expo-font",
      "expo-web-browser"
    ],
    "extra": {
      "apiUrl": "https://tasknote-api.onrender.com/api",
      "eas": {
        "projectId": "your-project-id"
      }
    },
    "android": {
      "package": "com.anonymous.guspad",
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [{ "scheme": "guspad", "host": "auth", "pathPrefix": "/callback" }],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    },
    "ios": {
      "bundleIdentifier": "com.anonymous.guspad"
    },
    "scheme": "guspad"
  }
}
